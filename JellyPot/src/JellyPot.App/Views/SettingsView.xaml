<UserControl x:Class="JellyPot.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:JellyPot.App.Behaviors">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" behaviors:SmoothScrollBehavior.IsEnabled="True">
            <StackPanel Margin="34,26,42,40" MaxWidth="1080" HorizontalAlignment="Left">
                <Button Content="←  返回电影库" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Padding="0,8" />
                <TextBlock Text="设置与路径" FontSize="30" FontWeight="Bold" Margin="0,18,0,0" />
                <TextBlock Text="在一个地方完成服务器、播放器和路径映射配置。" Foreground="{StaticResource MutedTextBrush}" Margin="0,7,0,26" />

                <Border Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="210" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border Width="38" Height="38" CornerRadius="11" Background="#34263A" HorizontalAlignment="Left"><TextBlock Text="◉" Foreground="{StaticResource AccentBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                            <TextBlock Text="Jellyfin 服务器" FontSize="17" FontWeight="SemiBold" Margin="0,12,0,0" />
                            <TextBlock Text="元数据与用户状态来源" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="服务器地址" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,7" />
                            <Grid>
                                <TextBox Text="{Binding ServerBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="测试连接" Command="{Binding TestServerCommand}" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Margin="0,4,5,4" Padding="12,4" MinHeight="30" />
                            </Grid>
                            <TextBlock Text="支持局域网 HTTP；远程访问建议使用 HTTPS 或 VPN。" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionCard}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="210" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border Width="38" Height="38" CornerRadius="11" Background="#292440" HorizontalAlignment="Left"><TextBlock Text="▶" Foreground="#B49CFF" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                            <TextBlock Text="PotPlayer" FontSize="17" FontWeight="SemiBold" Margin="0,12,0,0" />
                            <TextBlock Text="直接打开原始媒体文件" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="可执行文件" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,7" />
                            <TextBox Text="{Binding PotPlayerExecutable, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="选择 EXE" Command="{Binding BrowsePlayerCommand}" Style="{StaticResource SecondaryButton}" Padding="14,7" />
                                <Button Content="自动查找" Command="{Binding AutoFindPlayerCommand}" Style="{StaticResource GhostButton}" Padding="14,7" Margin="7,0,0,0" />
                                <Button Content="测试启动" Command="{Binding TestPlayerCommand}" Style="{StaticResource GhostButton}" Padding="14,7" />
                            </StackPanel>
                            <CheckBox Content="PotPlayer 关闭后询问是否标记已观看" IsChecked="{Binding AskToMarkPlayedAfterExit}" Margin="0,15,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionCard}" Margin="0,16,0,0">
                    <StackPanel>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="路径映射" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="Jellyfin 路径按最长前缀转换成 Windows 本地或 UNC 路径" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                            </StackPanel>
                            <Button Content="＋ 添加映射" Command="{Binding AddMappingCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="14,7" />
                        </Grid>

                        <DataGrid ItemsSource="{Binding Mappings}" SelectedItem="{Binding SelectedMapping}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  Background="Transparent" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderBrush}" RowBackground="#11151D" AlternatingRowBackground="#151A23"
                                  HeadersVisibility="Column" RowHeight="44" ColumnHeaderHeight="38" Margin="0,18,0,0" Height="238">
                            <DataGrid.ColumnHeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#1B202A" /><Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" /><Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" /><Setter Property="Padding" Value="10,5" /></Style></DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle><Style TargetType="DataGridCell"><Setter Property="BorderThickness" Value="0" /><Setter Property="Padding" Value="8,4" /><Setter Property="VerticalContentAlignment" Value="Center" /><Setter Property="Foreground" Value="{StaticResource TextBrush}" /></Style></DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="58" />
                                <DataGridTextColumn Header="名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                <DataGridTextColumn Header="Jellyfin 服务器根路径" Binding="{Binding ServerRoot, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTextColumn Header="Windows 根路径" Binding="{Binding WindowsRoot, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="选择 Windows 文件夹" Command="{Binding BrowseWindowsRootCommand}" Style="{StaticResource GhostButton}" Padding="10,6" />
                            <Button Content="删除选中映射" Command="{Binding RemoveMappingCommand}" Style="{StaticResource GhostButton}" Foreground="{StaticResource ErrorBrush}" Padding="10,6" Margin="6,0,0,0" />
                        </StackPanel>

                        <Border Background="#10141B" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="15" Margin="0,17,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="样本 Jellyfin 路径" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,0,7" />
                                    <TextBox Text="{Binding SampleServerPath, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="实时转换预览" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,0,7" />
                                    <Border Background="#151B21" CornerRadius="5" MinHeight="40" Padding="12,8">
                                        <TextBlock Text="{Binding PreviewPath}" Foreground="{StaticResource SuccessBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Margin="0,22,0,0">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center">
                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}" /><Style.Triggers><DataTrigger Binding="{Binding StatusIsError}" Value="True"><Setter Property="Foreground" Value="{StaticResource ErrorBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                    </TextBlock>
                    <Button Content="保存设置" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" MinWidth="132" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
