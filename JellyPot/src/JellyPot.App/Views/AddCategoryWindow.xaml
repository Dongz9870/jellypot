<Window x:Class="JellyPot.App.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加媒体分类" Width="560" Height="650" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="添加媒体分类" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="将侧栏分类绑定到一个 Jellyfin 片源库，并可同时创建播放路径映射。" Foreground="{StaticResource MutedTextBrush}" Margin="0,7,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,26,0,0">
            <TextBlock Text="分类名称" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,7" />
            <TextBox x:Name="CategoryNameBox" />

            <TextBlock Text="媒体类型" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,18,0,7" />
            <ComboBox x:Name="MediaTypeBox" SelectionChanged="MediaTypeBox_OnSelectionChanged">
                <ComboBoxItem Content="电影" Tag="Movie" IsSelected="True" />
                <ComboBoxItem Content="电视" Tag="Series" />
            </ComboBox>

            <TextBlock Text="Jellyfin 片源库" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,18,0,7" />
            <ComboBox x:Name="LibraryBox" DisplayMemberPath="DisplayName" />

            <Border Background="#10141B" CornerRadius="9" Padding="15" Margin="0,22,0,0">
                <StackPanel>
                    <TextBlock Text="可选：同时创建播放路径映射" FontWeight="SemiBold" />
                    <TextBlock Text="服务端路径用于匹配 Jellyfin 返回的路径，Windows 路径可以是本地目录或 UNC。" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,14" />
                    <TextBlock Text="Jellyfin 服务器根路径" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,0,6" />
                    <TextBox x:Name="ServerRootBox" />
                    <TextBlock Text="Windows 实际根路径" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,13,0,6" />
                    <Grid>
                        <TextBox x:Name="WindowsRootBox" Padding="12,8,88,8" />
                        <Button Content="选择" Click="BrowseWindowsRoot_OnClick" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Margin="0,4,5,4" Padding="12,4" MinHeight="30" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="取消" Click="Cancel_OnClick" Style="{StaticResource GhostButton}" MinWidth="88" />
            <Button Content="添加分类" Click="Add_OnClick" Style="{StaticResource PrimaryButton}" MinWidth="116" Margin="10,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
