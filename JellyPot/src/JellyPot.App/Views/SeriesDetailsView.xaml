<UserControl x:Class="JellyPot.App.Views.SeriesDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:JellyPot.App.Behaviors">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" behaviors:SmoothScrollBehavior.IsEnabled="True">
            <Grid Margin="34,26,40,38">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Button Content="←  返回电视库" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Padding="0,8" />

                <Grid Grid.Row="1" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="280" /><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <Border Height="415" CornerRadius="14" Background="{StaticResource SurfaceRaisedBrush}" ClipToBounds="True" CacheMode="BitmapCache">
                            <Grid>
                                <Border>
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#342A40" /><GradientStop Color="#151923" Offset="1" /></LinearGradientBrush></Border.Background>
                                    <TextBlock Text="{Binding Series.Initial}" FontSize="104" FontWeight="Black" Foreground="#574861" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <Image Source="{Binding Series.PosterUrl}" Stretch="UniformToFill" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SectionCard}" Margin="0,16,0,0" Padding="16">
                            <StackPanel>
                                <TextBlock Text="剧集统计" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                <TextBlock Text="{Binding SummaryText, Mode=OneWay}" FontWeight="SemiBold" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="电视剧" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Series.Name}" FontSize="38" FontWeight="Bold" TextWrapping="Wrap" Margin="0,9,0,0" />
                        <TextBlock Text="{Binding Series.OriginalTitle}" FontSize="15" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                        <TextBlock Text="{Binding Series.Overview, TargetNullValue=暂无简介}" Foreground="#C3CAD5" TextWrapping="Wrap" LineHeight="23" Margin="0,18,0,0" MaxWidth="860" HorizontalAlignment="Left" />

                        <Grid Margin="0,26,0,10">
                            <TextBlock Text="单集列表" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding Seasons}" SelectedItem="{Binding SelectedSeason}" DisplayMemberPath="Name"
                                      Width="150" HorizontalAlignment="Right" />
                        </Grid>

                        <ListBox ItemsSource="{Binding VisibleEpisodes}" SelectedItem="{Binding SelectedEpisode}" Height="330"
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,7" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#332A3F" /></Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14,11">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /><ColumnDefinition Width="105" /><ColumnDefinition Width="80" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding EpisodeNumberText, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationText, Mode=OneWay}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{Binding ProgressText, Mode=OneWay}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Style="{StaticResource SectionCard}" Margin="0,16,0,0" Padding="17" DataContext="{Binding SelectedEpisodeDetails}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Movie.Name}" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VideoInfo, Mode=OneWay}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <Button Content="▶  播放本集" Command="{Binding PlayCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Padding="20,10" />
                                </Grid>
                                <TextBlock Grid.Row="1" Text="{Binding WindowsPath}" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource SuccessBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,15,0,0" />
                                <TextBlock Grid.Row="2" Text="{Binding PathStatus}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,7,0,0" />
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,14,0,0" TextWrapping="Wrap" />
                        <Button Content="调整路径映射" Command="{Binding SettingsCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,16,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Background="#A60B0D12" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="150" Height="3" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="正在加载单集…" Foreground="{StaticResource MutedTextBrush}" Margin="0,13,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
