<UserControl x:Class="JellyPot.App.Views.MovieDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:JellyPot.App.Behaviors">
    <ScrollViewer VerticalScrollBarVisibility="Auto" behaviors:SmoothScrollBehavior.IsEnabled="True">
        <Grid Margin="34,26,40,36">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Button Content="←  返回电影库" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Padding="0,8" />

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="300" /><ColumnDefinition Width="44" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <Border Height="444" CornerRadius="14" Background="{StaticResource SurfaceRaisedBrush}" ClipToBounds="True">
                        <Grid>
                            <Border>
                                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#342A40" /><GradientStop Color="#151923" Offset="1" /></LinearGradientBrush></Border.Background>
                                <TextBlock Text="{Binding Movie.Initial}" FontSize="110" FontWeight="Black" Foreground="#574861" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Image Source="{Binding Movie.PosterUrl}" Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource SectionCard}" Margin="0,18,0,0" Padding="16">
                        <StackPanel>
                            <TextBlock Text="播放路径" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PathStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="11" Margin="0,7,0,0" />
                            <TextBlock Text="{Binding MappingName, StringFormat=映射：{0}}" Foreground="{StaticResource SuccessBrush}" FontSize="11" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="5" Padding="8,4" ToolTip="{Binding SelectedResolutionDetailText}"><TextBlock Text="{Binding SelectedResolutionText}" FontSize="10" FontWeight="Bold" /></Border>
                        <Border CornerRadius="5" Padding="8,4" Margin="7,0,0,0" ToolTip="{Binding SelectedDynamicRangeDetailText}"
                                Visibility="{Binding SelectedHasDynamicRange, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#3A414F" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedDynamicRangeText}" Value="HDR"><Setter Property="Background" Value="#823B64" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedDynamicRangeText}" FontSize="10" FontWeight="Bold" />
                        </Border>
                        <Border Background="#295D8F" CornerRadius="5" Padding="8,4" Margin="7,0,0,0" ToolTip="{Binding SelectedBluRayDetailText}"
                                Visibility="{Binding SelectedHasBluRay, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="蓝光" Foreground="#D9ECFF" FontSize="10" FontWeight="Bold" />
                        </Border>
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="5" Padding="8,4" Margin="7,0,0,0"><TextBlock Text="{Binding Movie.ProgressText}" FontSize="10" /></Border>
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="5" Padding="8,4" Margin="7,0,0,0"><TextBlock Text="原文件直读" Foreground="{StaticResource SuccessBrush}" FontSize="10" /></Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Movie.Name}" FontSize="40" FontWeight="Bold" TextWrapping="Wrap" Margin="0,18,0,0" />
                    <TextBlock Text="{Binding Movie.OriginalTitle}" FontSize="16" Foreground="{StaticResource MutedTextBrush}" Margin="0,7,0,0" />
                    <TextBlock Margin="0,17,0,0" Foreground="{StaticResource MutedTextBrush}">
                        <Run Text="{Binding Movie.YearText, Mode=OneWay}" /><Run Text="   ·   " /><Run Text="{Binding Movie.DurationText, Mode=OneWay}" /><Run Text="   ·   " /><Run Text="{Binding Movie.RatingText, Mode=OneWay, StringFormat=★ {0}}" />
                    </TextBlock>
                    <TextBlock Text="{Binding GenresText}" Foreground="{StaticResource AccentBrush}" Margin="0,12,0,0" />

                    <TextBlock Text="剧情简介" FontSize="17" FontWeight="SemiBold" Margin="0,30,0,0" />
                    <TextBlock Text="{Binding Movie.Overview, TargetNullValue=暂无简介}" Foreground="#C3CAD5" TextWrapping="Wrap" LineHeight="24" FontSize="14" Margin="0,11,0,0" MaxWidth="820" HorizontalAlignment="Left" />

                    <Grid Margin="0,30,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,9,0">
                            <StackPanel><TextBlock Text="视频规格" Foreground="{StaticResource MutedTextBrush}" FontSize="11" /><TextBlock Text="{Binding VideoInfo}" FontWeight="SemiBold" Margin="0,7,0,0" /></StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="9,0,0,0">
                            <StackPanel><TextBlock Text="观看状态" Foreground="{StaticResource MutedTextBrush}" FontSize="11" /><TextBlock Text="{Binding Movie.ProgressText}" FontWeight="SemiBold" Margin="0,7,0,0" /></StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="播放版本" FontSize="13" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" DisplayMemberPath="DisplayName" MaxWidth="560" HorizontalAlignment="Stretch" />

                    <Border Style="{StaticResource SectionCard}" Margin="0,18,0,0" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Jellyfin 服务器路径" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                            <TextBlock Text="{Binding ServerPath}" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,12" />
                            <TextBlock Text="Windows 实际路径" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                            <TextBlock Text="{Binding WindowsPath}" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource SuccessBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                        <Button Content="▶  使用 PotPlayer 播放" Command="{Binding PlayCommand}" Style="{StaticResource PrimaryButton}" Padding="24,12" />
                        <Button Content="调整路径映射" Command="{Binding SettingsCommand}" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
